{
  "manifest_version": 3,
  "name": "YouTube Shorts Limiter",
  "version": "1.0.0",
  "description": "Prevents doom-scrolling youtube shorts, while allowing to view a single short",
  "icons": {
  },
  "web_accessible_resources": [
    {
      "resources": [],
      "matches": ["https://www.youtube.com/*"]
    }
  ],
  "content_scripts": [
    {
      "matches": ["https://www.youtube.com/*"],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ]
}
